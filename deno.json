{
  "license": "./LICENSE",
  "tasks": {
    "clean-dist": "rm -r ./dist/* || exit 0",
    "install": "deno install",
    "build": {
      "description": "Build the app for production.",
      "command": "deno run -A ./config/build/index.ts",
      "dependencies": [ "clean-dist" ]
    },
    "build:watch": {
      "description": "Build the app for production with watcher.",
      "command": "deno run -A ./config/build/index.ts --watch",
      "dependencies": [ "clean-dist" ]
    },
    "build:dev": {
      "description": "Build the app for development.",
      "command": "deno run -A ./config/build/index.ts --develope",
      "dependencies": [ "clean-dist" ]
    },
    "build:dev:watch": {
      "description": "Build the app for development with watcher.",
      "command": "deno run -A ./config/build/index.ts --develope --watch",
      "dependencies": [ "clean-dist" ]
    },
    "cache": "deno cache --reload .",
    "serve": {
      "description": "Run the server on port 8000 for production.",
      "command": "deno run -A ./src/server/index.ts --port=8000",
      "dependencies": [ "build" ]
    },
    "serve:dev": {
      "description": "Run the server on port 8000 for development.",
      "command": "deno run -A ./src/server/index.ts --develope --port=8000",
      "dependencies": [ "build" ]
    },
    "lint": "deno lint",
    "test": {
      "description": "Run unit tests. Junit reports will be saved to \"./reports/report.xml\".",
      "command": "deno test -A --check --reload --doc --permit-no-files --junit-path=\"./reports/report.xml\"",
      "dependencies": [ "build" ]
    }
  },
  "lock": "./config/lock.json",
  "importMap": "./config/import_map.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "experimentalDecorators": true,
    "lib": [
      "esnext",
      "dom",
      "webworker"
    ],
    "types": [
      "./config/types/scss.d.ts"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "npm:solid-js"
  },
  "exclude": [
    "./dist/"
  ],
  "test": {
    "include": [
      "**/*.test.ts"
    ]
  },
  "lint": {
    "plugins": [
      "https://raw.githubusercontent.com/DenoPlayground/lint-plugins/refs/heads/main/src/types/type_colon_spacing.ts"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "camelcase",
        "default-param-last",
        "eqeqeq",
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "guard-for-in",
        "no-const-assign",
        "no-eval",
        "no-external-import",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-self-compare",
        "no-sparse-arrays",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-undef",
        "prefer-ascii",
        "single-var-declarator",
        "verbatim-module-syntax"
      ],
      "exclude": [
        "no-inferrable-types"
      ]
    }
  },
  "fmt": {
    "options": {
      "singleQuote": true,
      "lineWidth": 120
    }
  }
}
